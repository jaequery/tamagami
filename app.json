{
  "expo": {
    "name": "tamagami",
    "slug": "tamagami",
    "version": "1.0.6",
    "scheme": "tamagami",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tamagami.app",
      "appleTeamId": "7BWUZV469T",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.tamagami.app"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSBluetoothAlwaysUsageDescription": "TAMAGAMI uses Bluetooth to let your pet meet other TAMAGAMI pets nearby."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff",
          "iosDisplayInForeground": true
        }
      ],
      "@bacons/apple-targets"
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.tamagami.app.widget",
                  "targetName": "TamaWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.tamagami.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "8032ef3b-0b02-4f4b-af3e-8200012ea133"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/8032ef3b-0b02-4f4b-af3e-8200012ea133"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
